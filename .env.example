# CloudFrontのURL (例: https://dxxxxxxxxxxxxx.cloudfront.net)
BASE_URL=

# CDK出力 CognitoHostedUiDomain を設定 (末尾スラッシュなし)
# 例: https://my-totp-demo.auth.ap-northeast-1.amazoncognito.com
COGNITO_DOMAIN=

# CDK出力 UserPoolClientId
COGNITO_CLIENT_ID=

# テスト用ユーザー
TEST_USERNAME=
TEST_PASSWORD=

# 初回登録時に認証アプリへ登録したBase32シークレット
TOTP_SECRET=
