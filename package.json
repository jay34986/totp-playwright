{
  "name": "totp-playwright",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint . --ext .ts",
    "test": "npm run test:unit",
    "test:unit": "tsx --test test/totp-playwright-stack.test.ts",
    "test:e2e": "playwright test --project e2e",
    "test:e2e:headed": "playwright test --project e2e --headed",
    "test:auth": "playwright test --project setup",
    "cdk:synth": "cdk synth",
    "cdk:diff": "cdk diff",
    "cdk:deploy": "cdk deploy --require-approval never",
    "cdk:destroy": "cdk destroy --force"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.7.2",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "aws-cdk": "^2.1030.0",
    "eslint": "^9.37.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.220.0",
    "cdk-nag": "^2.37.55",
    "constructs": "^10.4.2",
    "dotenv": "^17.2.3",
    "otplib": "^12.0.1"
  }
}
